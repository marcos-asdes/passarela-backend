{
  "name": "passarela-backend",
  "version": "0.1.0",
  "description": "Passarela — MVP de plataforma de ofertas relâmpago para lojistas e compradores de shopping centers. Backend NestJS com arquitetura DDD.",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "nest build",
    "start": "cross-env NODE_OPTIONS=\"-r tsconfig-paths/register\" TS_NODE_BASE_URL=./dist nest start -b swc",
    "start:dev": "cross-env NODE_OPTIONS=\"-r tsconfig-paths/register\" TS_NODE_BASE_URL=./dist nest start -b swc --watch",
    "start:debug": "cross-env NODE_OPTIONS=\"-r tsconfig-paths/register\" TS_NODE_BASE_URL=./dist nest start -b swc --watch --debug",
    "start:prod": "cross-env NODE_OPTIONS=\"-r tsconfig-paths/register\" TS_NODE_BASE_URL=./dist node dist/src/main.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "format": "prettier --write \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" \"__tests__/**/*.ts\" --fix"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.5.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "^8.2.0",
    "mongoose": "^9.7.3",
    "ms": "^2.1.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/ms": "^2.1.0",
    "@types/node": "^26.1.0",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "chokidar": "^5.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "prettier": "^3.9.4",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "overrides": {
    "multer": "^2.2.0"
  }
}
