# Ambiente de execução: development | production | test
NODE_ENV=development

# Porta HTTP da API
PORT=3000

# Credenciais do usuário root do MongoDB — gerar usuário e senha fortes (15+ caracteres),
# distintos por ambiente (dev, prod). Nunca reaproveitar a mesma senha entre ambientes.
MONGO_ROOT_USER=userdev
MONGO_ROOT_PASSWORD=troque-por-uma-senha-forte-de-15-caracteres

# String de conexão do MongoDB (no docker compose, o host é o nome do serviço "mongo").
# Usuário/senha aqui devem ser os mesmos definidos em MONGO_ROOT_USER/MONGO_ROOT_PASSWORD acima.
MONGODB_URI=mongodb://userdev:troque-por-uma-senha-forte-de-15-caracteres@mongo:27017/passarela?authSource=admin

# Visibilidade do log do mongod, controlada na fonte (não no driver do Docker — isso apaga tanto
# "docker compose logs" quanto o attach ao vivo de "docker compose up" sem -d).
# /dev/stdout (padrão) = log visível. /dev/null = log completamente invisível.
# Exige recriar o container mongo para aplicar (docker compose up -d --force-recreate mongo).
MONGO_LOG_PATH=/dev/stdout

# Origem permitida para CORS (nunca usar * em produção)
CORS_ORIGIN=http://localhost:3000

# Rate limiting (@nestjs/throttler): janela em milissegundos e número máximo de requisições na janela
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
